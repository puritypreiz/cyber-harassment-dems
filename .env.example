# Copy to .env and fill in real secrets. Never commit the real .env file.

FLASK_ENV=production
SECRET_KEY=change-this-to-a-long-random-value
JWT_SECRET_KEY=change-this-to-a-different-long-random-value

# Base64-encoded 32-byte key, e.g. `python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"`
EVIDENCE_ENCRYPTION_KEY=
QR_SIGNING_KEY=change-this-to-a-long-random-value

DATABASE_URL=sqlite:///cyber_harassment_dems.db

# Only used by docker-compose.yml's Postgres service
POSTGRES_PASSWORD=

MAX_UPLOAD_MB=50

# Comma-separated list of origins allowed to call the JSON API from a browser (leave blank to disable cross-origin API calls)
ALLOWED_ORIGINS=

# Optional email/SMS provider credentials (leave blank to run notifications in dry-run/log-only mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=noreply@example.org
SMS_PROVIDER_API_KEY=

NATIONAL_HOTLINE_NUMBER=1-800-000-0000
